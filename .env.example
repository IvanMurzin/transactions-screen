# Backend deploy environment used by scripts/supabase-* helpers.
# Copy to `.env` and fill with values from your Supabase project.
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_DB_PASSWORD=your_db_password

# RevenueCat — required if subscriptions are enabled in the client.
# Server-side secret API key (NOT the SDK public key) used by the webhook
# and `/revenuecat/refresh` to read subscriber entitlements.
REVENUECAT_API_KEY=

# Shared secret sent by RevenueCat in the webhook Authorization header.
# Configure the same value in RevenueCat → Project → Integrations → Webhook.
REVENUECAT_WEBHOOK_SECRET=

# Entitlement id(s) that grant the `pro` plan. Either one is enough.
REVENUECAT_PRO_ENTITLEMENT=pro
# REVENUECAT_PRO_ENTITLEMENTS=pro,premium
